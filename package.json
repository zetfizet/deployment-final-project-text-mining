{
  "name": "deploy-final-project",
  "version": "1.0.0",
  "description": "Monorepo for Emotion & Sentiment Analysis",
  "scripts": {
    "dev": "npm i concurrently && concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:backend": "cd backend && .\\venv\\Scripts\\activate && uvicorn main:app --reload --port 8000"
  },
  "dependencies": {
    "concurrently": "^10.0.3"
  }
}
